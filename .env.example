# Supabase — copia a .env y reinicia: npx expo start --clear
# Dashboard → Project Settings → API → Project URL + anon public (JWT eyJhbGci…)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# IMPORTANTE: usa la clave "anon public" en formato JWT (eyJhbGci…).
# La clave "publishable" (sb_publishable_…) suele dar "Invalid API key" con supabase-js.
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Google OAuth (Authentication → Providers → Google en Supabase)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com

# ─── Supabase: Authentication → URL Configuration ───
# Site URL (solo http o https — NO pongas rpgskilltree:// aquí):
#   Desarrollo web:  http://localhost:8081
#   Producción:      https://tu-dominio.vercel.app
#
# Redirect URLs (lista aparte; una URL por línea):
#   http://localhost:8081/auth/callback
#   http://localhost:8081/**
#   https://tu-dominio.vercel.app/auth/callback
#   rpgskilltree://auth/callback          ← solo en Redirect URLs, no en Site URL
#
# Google Cloud Console → OAuth client → Authorized redirect URIs:
#   https://YOUR-PROJECT-REF.supabase.co/auth/v1/callback
