# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth (Web Client ID — el mismo que configuras en Supabase → Auth → Google)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Redirect URIs a registrar en Supabase (Authentication → URL Configuration):
# - http://localhost:8081/auth/callback   (Expo web dev)
# - https://tu-dominio.com/auth/callback  (producción web)
# - rpgskilltree://auth/callback            (Expo Go / app nativa)
